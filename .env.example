# ─── Clés API obligatoires ────────────────────────────────────────────────────

# OpenAI — requis pour LLM (GPT-4o) et embeddings
OPENAI_API_KEY=sk-...

# ─── Clés API optionnelles ────────────────────────────────────────────────────

# INSEE API — pour le benchmarking Esane
# Inscription gratuite : https://api.insee.fr/
# Sans cette clé, le benchmark bascule directement sur le LLM
INSEE_API_KEY=

# ─── Configuration modèle (valeurs par défaut) ────────────────────────────────

# Modèle LLM principal
LLM_MODEL=gpt-4o

# Modèle pour les embeddings RAG
EMBEDDING_MODEL=text-embedding-3-small

# ─── Chemins par défaut ───────────────────────────────────────────────────────

# Chemin vers le catalogue de missions du cabinet
CATALOGUE_PATH=data/catalogue_missions.json

# Répertoire de cache pour les données BdF (évite les appels répétés)
BDF_CACHE_DIR=data/bdf_cache

# Seuil pour basculer sur le RAG (nombre de missions dans le catalogue)
RAG_THRESHOLD=50

# LangSmith (observability - optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=rdv-bilan-ia
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com


# ─── Analyse sectorielle & Slides ────────────────────────────────────────────

# Perplexity — analyse sectorielle sourcée (INSEE, BdF, CCI)
# Sans cette clé, le pipeline bascule sur une estimation GPT-4o
PERPLEXITY_API_KEY=

# Gamma — génération automatique de présentation 10 slides
# Sans cette clé, seul le contenu Markdown est généré (pas de slides)
GAMMA_API_KEY=
